# ── Servidor ──
PORT=3000
NODE_ENV=development

# ── Base de datos (MongoDB Atlas) ── REQUERIDO
ATLAS_URL=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# ── Cloudinary (imágenes) ──
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# ── JWT ── REQUERIDO
JWT_SECRET=tu_jwt_secret_seguro
JWT_EXPIRES_IN=8h

# ── Frontend (CORS + links en emails) ──
FRONTEND_URL=http://localhost:4200,http://localhost:5173

# ── Uploads ──
UPLOAD_PATH=uploads

# ── Seguridad login ──
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=30

# ── SMTP (Gmail) ── opcional, sin esto los correos se simulan
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM=noreply@vayo.cl

# ── Backup automático ──
BACKUP_ENABLED=true
BACKUP_CRON=0 3 * * *
BACKUP_KEEP=7

# ── Transbank Webpay Plus ──────────────────────────────────────────────────────
# URL pública de este backend (Webpay redirige al usuario de vuelta aquí)
BACKEND_URL=http://localhost:3000

# Entorno: 'integration' (sandbox) o 'production'
TBK_ENV=integration

# Credenciales de PRODUCCIÓN (dejar vacías en sandbox — el SDK usa las de integración)
TBK_COMMERCE_CODE=<tu_código_de_comercio_transbank>
TBK_API_KEY=<tu_api_key_secreta_transbank>
